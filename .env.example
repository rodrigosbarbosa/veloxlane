# VeloxLane environment variables. Copy to .env for local development.

# Core
NODE_ENV=development
APP_ENV=local
WEB_APP_URL=http://localhost:3000
ADMIN_APP_URL=http://localhost:3001
API_BASE_URL=http://localhost:4000

# Database / cache
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/veloxlane?schema=public
REDIS_URL=redis://localhost:6379

# Firebase Auth (Week 2)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=

# AWS (Week 1 account; credentials supplied when infra work begins)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=
CLOUDFRONT_DISTRIBUTION_ID=

# Stripe platform fees + Stripe Identity (Week 3)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Twilio phone OTP (Week 3)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=

# Escrow.com vehicle transaction escrow (Week 4)
ESCROW_COM_API_KEY=
ESCROW_COM_EMAIL=
ESCROW_COM_BASE_URL=https://api.escrow-sandbox.com/2017-09-01

# CARFAX vehicle history (Week 4)
CARFAX_API_KEY=
CARFAX_BASE_URL=

# Marketcheck fair-price data (Week 4/P1)
MARKETCHECK_API_KEY=

# Google Maps / Places (Week 5)
GOOGLE_MAPS_API_KEY=

# SendGrid transactional email (Week 5)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=

# Analytics / monitoring (Week 5)
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# Mobile / Expo (Week 8)
EXPO_TOKEN=
EAS_PROJECT_ID=
