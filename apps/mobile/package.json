{
  "name": "@veloxlane/mobile",
  "version": "0.0.0",
  "private": true,
  "description": "VeloxLane Expo mobile app",
  "type": "module",
  "main": "expo-router/entry",
  "scripts": {
    "build": "expo export --platform web",
    "dev": "expo start",
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@babel/runtime": "^7.29.2",
    "@expo-google-fonts/inter": "^0.2.3",
    "@expo/metro-runtime": "~3.2.3",
    "@veloxlane/design-tokens": "workspace:*",
    "expo": "~51.0.39",
    "expo-asset": "~10.0.10",
    "expo-font": "~12.0.10",
    "expo-router": "~3.5.24",
    "expo-status-bar": "~1.12.1",
    "lucide-react-native": "^0.511.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-native": "0.74.5",
    "react-native-safe-area-context": "4.10.5",
    "react-native-screens": "3.31.1",
    "react-native-svg": "15.2.0",
    "react-native-web": "~0.19.10"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "vitest": "^2.1.8"
  }
}
